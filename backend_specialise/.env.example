# InFrench Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# === REQUIRED ===
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# === CORS ===
# Separer par des virgules pour plusieurs origines
ALLOWED_ORIGINS=http://localhost:3000,https://infrench.vercel.app

# === OPTIONAL ===
# Limites upload
MAX_FILE_SIZE_MB=500

# Rate limiting
RATE_LIMIT_UPLOADS=10/hour

# Nettoyage fichiers temporaires
TEMP_FILE_MAX_AGE_HOURS=24

# TTS Voice (Vivian, Serena, Dylan, Eric, Ryan, Aiden, etc.)
TTS_DEFAULT_VOICE=Vivian
